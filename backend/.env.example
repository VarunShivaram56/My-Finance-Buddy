APP_ENV=development
DATABASE_URL=sqlite:///./backend/my_finance_buddy.db
AGENT_ONE_API_KEY=
AGENT_TWO_API_KEY=
AGENT_THREE_API_KEY=
AGENT_ONE_MODEL=groq/compound
AGENT_TWO_MODEL=groq/compound
AGENT_THREE_MODEL=openai/gpt-oss-120b
EMBEDDING_MODEL=nomic-embed-text
CHROMA_DIR=./chroma_data
LLM_CONFIDENCE_THRESHOLD=0.65
LLM_BATCH_SIZE=25
MAX_INSIGHT_TRANSACTIONS=40
ENABLE_AI_INSIGHTS=true
ENABLE_VECTOR_MEMORY=false
MAX_LLM_CATEGORIZATION_MERCHANTS=40
MAX_AI_INSIGHT_STATEMENT_SIZE=80
