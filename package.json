{
  "name": "my-finance-buddy",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "npm --prefix frontend start",
    "backend": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend.ps1",
    "backend:no-reload": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend.ps1 -NoReload"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
